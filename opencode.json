{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "flowbite": {
      "type": "local",
      "command": ["npx", "-y", "flowbite-mcp"],
      "enabled": true
    }
  }
}
