{
  "name": "wouaff-client",
  "version": "1.0.1",
  "description": "Wouaff — Chat privé et sécurisé",
  "author": "Biston",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run gen:splash && concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "tsc -b && vite build",
    "gen:splash": "node scripts/gen_splash.cjs",
    "build:electron": "npm run build && npm run gen:splash && electron-builder --win --config electron-builder.yml",
    "build:electron:mac": "npm run build && npm run gen:splash && electron-builder --mac --config electron-builder.yml",
    "build:electron:linux": "npm run build && npm run gen:splash && electron-builder --linux --config electron-builder.yml",
    "build:electron:all": "npm run build && npm run gen:splash && electron-builder --win --mac --linux --config electron-builder.yml",
    "publish:win": "npm run build && npm run gen:splash && node scripts/publish.cjs --win --config electron-builder.yml --publish always",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.wouaff.app",
    "productName": "Wouaff",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/assets/logo/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/assets/logo/icon.png",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/assets/logo",
      "category": "Network"
    },
    "publish": {
      "provider": "github",
      "owner": "youtsuhodev",
      "repo": "wouaff-app"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerLanguages": [
        "fr_FR",
        "en_US"
      ]
    }
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "events": "^3.3.0",
    "lucide-react": "^1.17.0",
    "process": "^0.11.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "simple-peer": "^9.11.1",
    "socket.io-client": "^4.8.0",
    "vite-plugin-node-polyfills": "^0.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/simple-peer": "^9.11.9",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  }
}
